  "main": "index.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- tsx watch src/app.ts",
    "build": "rimraf dist && tsup",
    "start": "node dist/app.js",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:migrate:test": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test": "npm run prisma:migrate:test && node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm run prisma:migrate:test && node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll",
    "test:coverage": "npm run prisma:migrate:test && node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
